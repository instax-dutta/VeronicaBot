{
    "name": "veronicabot",
    "version": "2.1.0",
    "description": "Production-grade Discord bot for YouTube and Twitch live notifications",
    "main": "src/index.js",
    "type": "module",
    "engines": {
        "node": ">=18.0.0"
    },
    "scripts": {
        "start": "node src/index.js",
        "dev": "node --watch src/index.js",
        "dev:all": "concurrently -n BOT,DASH -c cyan,magenta \"npm run dev\" \"npm run dev --prefix dashboard\"",
        "import": "node src/importers/creators.js",
        "twitch-auth": "node scripts/twitch-auth.js"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/instax-dutta/VeronicaBot.git"
    },
    "keywords": [
        "discord",
        "bot",
        "youtube",
        "twitch",
        "live",
        "notifications",
        "streaming",
        "neondb",
        "redis"
    ],
    "author": "sdad.pro",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/instax-dutta/VeronicaBot/issues"
    },
    "homepage": "https://github.com/instax-dutta/VeronicaBot#readme",
    "dependencies": {
        "@upstash/redis": "^1.28.0",
        "axios": "^1.6.7",
        "better-sqlite3": "^12.8.0",
        "bottleneck": "^2.19.5",
        "cors": "^2.8.6",
        "discord.js": "^14.25.1",
        "dotenv": "^16.4.1",
        "express": "^5.2.1",
        "jsonwebtoken": "^9.0.3",
        "pg": "^8.11.3",
        "ws": "^8.19.0",
        "xml2js": "^0.6.2"
    },
    "overrides": {
        "undici": "^7.3.0"
    },
    "devDependencies": {
        "concurrently": "^9.2.1"
    }
}
