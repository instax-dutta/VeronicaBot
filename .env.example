# ===========================================
# DISCORD CONFIGURATION
# ===========================================
# Get from: https://discord.com/developers/applications
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# Bot Application ID (Client ID) - Required for slash commands
# Found in Discord Developer Portal -> Your App -> General Information
DISCORD_CLIENT_ID=YOUR_DISCORD_CLIENT_ID_HERE
DEV_GUILD_ID=YOUR_DEV_GUILD_ID_HERE

# ===========================================
# BOT CUSTOMIZATION
# ===========================================
# Custom bot name displayed in embeds (optional)
BOT_NAME=Veronica

# Bot activity status shown in Discord
# Options: online, idle, dnd, invisible
BOT_STATUS=online

# Bot activity type: PLAYING, WATCHING, LISTENING, COMPETING
BOT_ACTIVITY_TYPE=WATCHING

# Bot activity text (e.g., "WATCHING 150 creators")
BOT_ACTIVITY_TEXT=live streams

# Admin role ID or user IDs that can use management commands (comma-separated)
# Leave empty to allow all server admins
BOT_ADMIN_IDS=

# ===========================================
# YOUTUBE CONFIGURATION
# ===========================================
# Get from: https://console.cloud.google.com/apis/credentials
# Enable "YouTube Data API v3" in your project
YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY_HERE

# ===========================================
# TWITCH CONFIGURATION
# ===========================================
# Get from: https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=YOUR_TWITCH_CLIENT_ID_HERE
TWITCH_CLIENT_SECRET=YOUR_TWITCH_CLIENT_SECRET_HERE

# ===========================================
# POLLING INTERVALS (in milliseconds)
# ===========================================
# YouTube uses RSS feeds (free) so can poll more frequently
YOUTUBE_POLL_INTERVAL=120000

# Twitch has generous rate limits
TWITCH_POLL_INTERVAL=60000

# ===========================================
# RATE LIMITING
# ===========================================
# YouTube API has a daily quota of 10,000 units
# videos.list costs 1 unit per call
YOUTUBE_MAX_REQUESTS_PER_MINUTE=30

# Twitch allows 800 requests/minute
TWITCH_MAX_REQUESTS_PER_MINUTE=100

# ===========================================
# DATABASE - SQLite
# ===========================================
# Path to SQLite database file (relative to project root or absolute)
DATABASE_PATH=./data/veronica.db

# Enable verbose logging for SQL queries (optional, set to 'true' for debugging)
DATABASE_VERBOSE=false

# ===========================================
# CACHE - Upstash Redis (OPTIONAL)
# ===========================================
# Bot works fine without Redis (uses SQLite only).
# Redis adds caching for reduced latency on repeated checks.
# Get from: https://console.upstash.com/
# REST API credentials (not the Redis URL)
UPSTASH_REDIS_REST_URL=YOUR_UPSTASH_REDIS_REST_URL_HERE
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_REDIS_REST_TOKEN_HERE

# Cache TTL settings (in seconds)
REDIS_LIVE_TTL=300
REDIS_COOLDOWN_TTL=60
REDIS_RATELIMIT_TTL=60

# ===========================================
# LOGGING
# ===========================================
# Options: debug, info, warn, error
LOG_LEVEL=info

# Health check interval (in milliseconds)
HEALTH_CHECK_INTERVAL=600000


# ===========================================
# DASHBOARD API
# ===========================================
# Port for the REST API server (used by the dashboard)
API_PORT=3001

# Secret key for JWT token signing (generate a strong random string)
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
API_SECRET=YOUR_API_SECRET_HERE

# URL where the dashboard is hosted (for CORS)
DASHBOARD_URL=http://localhost:3000

# Discord OAuth2 Client Secret (for dashboard login)
# Found in Discord Developer Portal -> Your App -> OAuth2
DISCORD_CLIENT_SECRET=YOUR_DISCORD_CLIENT_SECRET_HERE
